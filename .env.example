# SATARK Layer 1 — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Application ────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-in-production
API_PORT=8000

# ── LLM Provider ───────────────────────────────────────────────
# CHANGE THIS SINGLE VALUE to switch providers. Nothing else changes.
#
#   development / cost-effective testing  →  LLM_PROVIDER=deepseek
#   production / final testing            →  LLM_PROVIDER=anthropic
#
LLM_PROVIDER=deepseek

# Anthropic (for production / final testing)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek (for development — much cheaper, OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat        # deepseek-chat (V3) or deepseek-reasoner (R1)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM call limits (same for both providers — from spec Section 3.7)
LLM_MAX_TOKENS=1000
LLM_SUBGRAPH_MAX_NODES=100
LLM_SUBGRAPH_MAX_EDGES=200

# ── Neo4j ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=satark-dev-password
NEO4J_SHARED_DB=vargplus_shared_reference

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_URI=postgresql://satark:satark-dev@localhost:5432/satark

# ── Redis ──────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TYPE_C=satark.findings.type_c

# ── Joern CPG service (code parsing) ─────────────────────────
JOERN_HOST=localhost
JOERN_PORT=8080

# ── Embedding model ────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Track 2 defaults (all configurable per tenant) ────────────
FINDING_CONFIDENCE_THRESHOLD=0.70
STALENESS_WINDOW_DAYS=30
REVIEW_QUEUE_SLA_DAYS=5
STUB_NODE_THRESHOLD_DAYS=30

FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential git \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.prototype.txt .
RUN pip install --no-cache-dir -r requirements.prototype.txt

COPY src/ ./src/

ENV PYTHONPATH=/app/src

CMD ["uvicorn", "src.main_prototype:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
